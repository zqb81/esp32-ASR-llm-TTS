# ============================================================
#  .env.example — 环境变量示例
#  复制为 .env 并填入真实值；.env 已在 .gitignore 中，不会提交
# ============================================================

# ---------- 小米 MiMo (ASR / LLM / TTS) ----------
# 申请地址: https://api.xiaomimimo.com
XIAOMI_API_KEY=sk-your_api_key_here

# ---------- 服务端网络 (server.py) ----------
# 监听地址 / 端口，默认 0.0.0.0:9000(TCP) / 8080(HTTP)
TCP_HOST=0.0.0.0
TCP_PORT=9000
HTTP_PORT=8080

# ---------- MQTT 桥接 (server.py → 本地 Mosquitto) ----------
MQTT_BRIDGE_HOST=127.0.0.1
MQTT_BRIDGE_PORT=1883

# ---------- ESP32 端配置 (烧录前填入 esp32/secrets.py) ----------
# 注意：MicroPython 不读 .env，下面这些仅供记录；
# 实际烧录时请把值抄进 esp32/secrets.py（复制自 esp32/secrets.example.py）
WIFI_SSID=your_wifi_name
WIFI_PASSWORD=your_wifi_password

# ESP32 连接的语音 / MQTT 服务器地址（云端或局域网 IP）
SERVER_IP=your_server_ip
SERVER_PORT=9000

MQTT_BROKER=your_server_ip
MQTT_PORT=1883
MQTT_CLIENT_ID=esp32_voice_iot_001

# ---------- 业务参数 ----------
# 天气查询默认城市
DEFAULT_CITY=广州

# ---------- 依赖 ----------
# server.py / xiaomi-mimo-2.5.py 可选依赖：python-dotenv（自动加载本文件）
#   pip install python-dotenv
# 不装也能用，直接在 shell 里 export 环境变量即可

# ---------- 提示 ----------
# 1. 本地调试：复制本文件为 .env，填入真值；server.py 会自动读取
# 2. 生产部署：把 .env 上传到服务器 /opt/esp-iot/.env，systemd 服务加载
# 3. ESP32 端：复制 esp32/secrets.example.py 为 esp32/secrets.py，填入真值
