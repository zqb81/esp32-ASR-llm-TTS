/* app.wxss — ESP32 IoT 小程序全局样式 (深色太空主题) */

page {
  /* 太空深邃配色变量 */
  --bg-base: #060913;
  --primary: #38bdf8;             /* 科技天蓝 */
  --primary-glow: rgba(56, 189, 248, 0.2);
  --success: #10b981;             /* 极客翠绿 */
  --success-glow: rgba(16, 185, 129, 0.2);
  --warning: #f59e0b;             /* 警示琥珀 */
  --warning-glow: rgba(245, 158, 11, 0.2);
  --danger: #f43f5e;              /* 报警珊瑚红 */
  --danger-glow: rgba(244, 63, 94, 0.2);
  
  --card-bg: rgba(13, 20, 38, 0.7);
  --card-border: rgba(255, 255, 255, 0.08);
  --text-main: #f8fafc;
  --text-secondary: #cbd5e1;
  --text-muted: #64748b;
  
  background: var(--bg-base);
  /* 太空蓝色微光渐变 */
  background-image: radial-gradient(circle at 50% -20%, #1e294b 0%, #060913 70%);
  background-attachment: fixed;
  color: var(--text-main);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  min-height: 100vh;
}

/* 通用玻璃卡片 */
.glass-card {
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(20px);
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding-bottom: 20rpx;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  letter-spacing: 1rpx;
}

.card-icon {
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 按钮基础 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx 28rpx;
  border: none;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.4;
  transition: all 0.2s ease;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #38bdf8, #0ea5e9);
  color: #060913;
  box-shadow: 0 4rpx 16rpx var(--primary-glow);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-danger {
  background: rgba(244, 63, 94, 0.15);
  border: 1rpx solid rgba(244, 63, 94, 0.3);
  color: #f43f5e;
}

.btn-danger:active {
  background: rgba(244, 63, 94, 0.25);
}

.btn-ghost {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  color: #94a3b8;
}

.btn-ghost:active {
  background: rgba(255, 255, 255, 0.08);
}

.btn-sm {
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  border-radius: 12rpx;
}

.btn-info {
  background: rgba(56, 189, 248, 0.12);
  border: 1rpx solid rgba(56, 189, 248, 0.25);
  color: #38bdf8;
}

.btn-warn {
  background: rgba(245, 158, 11, 0.12);
  border: 1rpx solid rgba(245, 158, 11, 0.25);
  color: #f59e0b;
}

/* 状态指示点 */
.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  display: inline-block;
  position: relative;
}

.status-dot.on {
  background: #10b981;
  box-shadow: 0 0 12rpx #10b981;
  animation: breathe-green 2s infinite ease-in-out;
}

.status-dot.off {
  background: #f43f5e;
  box-shadow: 0 0 12rpx #f43f5e;
}

/* 文本颜色辅助 */
.text-primary { color: #38bdf8; }
.text-success { color: #10b981; }
.text-warning { color: #f59e0b; }
.text-danger { color: #f43f5e; }
.text-muted { color: #64748b; }

/* 玻璃质感输入框 */
.glass-input {
  width: 100%;
  height: 82rpx;
  min-height: 82rpx;
  line-height: 82rpx;
  padding: 0 24rpx;
  background: rgba(6, 9, 19, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 18rpx;
  color: #f8fafc;
  font-size: 26rpx;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

/* 兼容 view 类型的玻璃框，如 picker */
view.glass-input {
  display: flex;
  align-items: center;
}

.glass-input-focus {
  border-color: var(--primary);
  box-shadow: 0 0 12rpx rgba(56, 189, 248, 0.15);
}

/* 滚动容器 */
.scroll-container {
  height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

/* ===== 核心动画定义 ===== */

/* 呼吸动画 - 绿色 */
@keyframes breathe-green {
  0%, 100% {
    opacity: 0.8;
    box-shadow: 0 0 6rpx #10b981;
  }
  50% {
    opacity: 1;
    box-shadow: 0 0 16rpx #10b981;
  }
}

/* 风扇转动动画 */
@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* 警报颤动动画 */
@keyframes wobble {
  0%, 100% { transform: rotate(0deg); }
  15% { transform: rotate(-8deg); }
  30% { transform: rotate(6deg); }
  45% { transform: rotate(-6deg); }
  60% { transform: rotate(4deg); }
  75% { transform: rotate(-2deg); }
}

/* 语音波纹扩散动画 */
@keyframes ripple {
  0% {
    transform: scale(1);
    opacity: 0.5;
  }
  100% {
    transform: scale(1.6);
    opacity: 0;
  }
}
